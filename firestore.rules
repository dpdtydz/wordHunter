rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      // User lhs41977@gmail.com is bootstrapped as admin
      return isSignedIn() && (request.auth.token.email == 'lhs41977@gmail.com' && request.auth.token.email_verified == true); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'experience', 'level', 'coins', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 7 && data.keys().size() <= 12
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 64
        && data.experience is int && data.experience >= 0
        && data.level is int && data.level >= 1
        && data.coins is int && data.coins >= 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidCharacter(data) {
      return data.keys().hasAll(['id', 'characterId', 'name', 'rarity', 'word', 'wordKorean', 'wordHint', 'visualEmoji', 'category', 'description', 'isShiny', 'capturedAt', 'count', 'level'])
        && data.keys().size() >= 14 && data.keys().size() <= 25
        && data.id is string
        && data.characterId is string
        && data.name is string && data.name.size() <= 256
        && data.rarity in ['Common', 'Uncommon', 'Rare', 'Unique', 'Epic', 'Legendary']
        && data.word is string && data.word.size() <= 128
        && data.wordKorean is string
        && data.wordHint is string
        && data.visualEmoji is string
        && data.category is string
        && data.description is string
        && data.isShiny is bool
        && (data.capturedAt is timestamp || data.capturedAt == request.time)
        && data.count is int
        && data.level is int
        && (data.keys().hasOnly(['id', 'characterId', 'name', 'rarity', 'word', 'wordKorean', 'wordHint', 'visualEmoji', 'category', 'description', 'isShiny', 'capturedAt', 'count', 'level', 'updatedAt', 'wordDefinition', 'imageUrl', 'characterName', 'charDescription']));
    }

    function isValidRanking(data) {
      return data.keys().hasAll(['userId', 'userName', 'totalWordsSolved', 'collectionCount', 'lastUpdatedAt'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 32
        && data.totalWordsSolved is int && data.totalWordsSolved >= 0
        && data.collectionCount is int && data.collectionCount >= 0
        && data.lastUpdatedAt == request.time;
    }

    // --- Collection Routes ---

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().updatedAt == request.time && 
        incoming().createdAt == existing().createdAt && 
        incoming().uid == existing().uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['experience', 'coins', 'level', 'updatedAt', 'displayName']);
    }

    // User's Character Collection (Sub-collection)
    match /users/{userId}/collection/{charId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidCharacter(incoming()) && isValidId(charId) && incoming().capturedAt == request.time;
      allow update: if isOwner(userId) && (
        // We allow both full overwrites (re-manifest) and partial increments
        isValidCharacter(incoming()) && 
        incoming().id == existing().id &&
        incoming().capturedAt == existing().capturedAt &&
        incoming().count >= existing().count &&
        incoming().level >= existing().level
      );
      allow delete: if isOwner(userId);
    }

    // Global Rankings
    match /rankings/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidRanking(incoming());
      allow update: if isOwner(userId) && (
        isValidRanking(incoming()) &&
        incoming().lastUpdatedAt == request.time &&
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['totalWordsSolved', 'collectionCount', 'lastUpdatedAt', 'userName'])
      );
    }

    // Global Vault (Shared resources)
    match /global_vault/{word} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}
